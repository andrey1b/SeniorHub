<Window x:Class="OfisPensionera.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppTitle}"
        Icon="app.ico"
        Height="560" Width="860"
        MinHeight="460" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        Background="#D0E8D0"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>

        <!-- Стиль плитки-кнопки -->
        <Style x:Key="TileStyle" TargetType="Button">
            <Setter Property="Width"  Value="152"/>
            <Setter Property="Height" Value="152"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="10">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="10"
                                                 ShadowDepth="3" Opacity="0.18"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.83"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка «Настройки» под цвет подвала -->
        <Style x:Key="SettingsBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#A8C8A8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#98B898"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#88A888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#2C5F2D" Padding="28,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🏠" FontSize="34" VerticalAlignment="Center"
                           Margin="0,0,14,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource AppTitle}"
                               FontFamily="Segoe UI" FontSize="26" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="tbSubtitle"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="#A8D5A9" Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Плитки -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="20,28,20,20" Orientation="Horizontal">

                <!-- Еда -->
                <Button Style="{StaticResource TileStyle}" Background="#1565C0"
                        Click="LaunchFood"
                        ToolTip="{DynamicResource TileFoodTip}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🍽️" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TileFood}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{DynamicResource TileFoodSub}"
                                   FontSize="11" Foreground="#B3D4FF"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="120"/>
                        <TextBlock x:Name="VerFood"
                                   FontSize="10" Foreground="#B3D4FF" Opacity="0.75"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Огород -->
                <Button Style="{StaticResource TileStyle}" Background="#2C5F2D"
                        Click="LaunchGarden"
                        ToolTip="{DynamicResource TileGardenTip}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🌱" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TileGarden}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{DynamicResource TileGardenSub}"
                                   FontSize="11" Foreground="#A8D5A9"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="120"/>
                        <TextBlock x:Name="VerGarden"
                                   FontSize="10" Foreground="#A8D5A9" Opacity="0.75"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Деньги -->
                <Button Style="{StaticResource TileStyle}" Background="#6A1B9A"
                        Click="LaunchHomeAccounting"
                        ToolTip="{DynamicResource TileMoneyTip}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🧾" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TileMoney}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{DynamicResource TileMoneySub}"
                                   FontSize="11" Foreground="#CE93D8"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="120"/>
                        <TextBlock x:Name="VerMoney"
                                   FontSize="10" Foreground="#CE93D8" Opacity="0.75"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Таблетки -->
                <Button Style="{StaticResource TileStyle}" Background="#B71C1C"
                        Click="LaunchMeds"
                        ToolTip="{DynamicResource TileMedsTip}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="💊" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TileMeds}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{DynamicResource TileMedsSub}"
                                   FontSize="11" Foreground="#FFCDD2"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="120"/>
                        <TextBlock x:Name="VerMeds"
                                   FontSize="10" Foreground="#FFCDD2" Opacity="0.75"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Аудиокниги -->
                <Button Style="{StaticResource TileStyle}" Background="#E65100"
                        Click="LaunchAudio"
                        ToolTip="{DynamicResource TileAudioTip}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🎧" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TileAudio}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{DynamicResource TileAudioSub}"
                                   FontSize="11" Foreground="#FFD0B0"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="120"/>
                        <TextBlock x:Name="VerAudio"
                                   FontSize="10" Foreground="#FFD0B0" Opacity="0.75"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Документы (PDF Drive) -->
                <Button Style="{StaticResource TileStyle}" Background="#00838F"
                        Click="LaunchPdf"
                        ToolTip="{DynamicResource TilePdfTip}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📄" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TilePdf}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{DynamicResource TilePdfSub}"
                                   FontSize="11" Foreground="#B2DFDB"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="120"/>
                        <TextBlock x:Name="VerPdf"
                                   FontSize="10" Foreground="#B2DFDB" Opacity="0.75"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Коммуналка (CommunalBills) -->
                <Button Style="{StaticResource TileStyle}" Background="#00695C"
                        Click="LaunchUtil"
                        ToolTip="{DynamicResource TileUtilTip}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="💡" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TileUtil}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{DynamicResource TileUtilSub}"
                                   FontSize="11" Foreground="#80CBC4"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="120"/>
                        <TextBlock x:Name="VerUtil"
                                   FontSize="10" Foreground="#80CBC4" Opacity="0.75"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Моя биография (MyBiography) -->
                <Button Style="{StaticResource TileStyle}" Background="#5D4037"
                        Click="LaunchBio"
                        ToolTip="{DynamicResource TileBioTip}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📖" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TileBio}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{DynamicResource TileBioSub}"
                                   FontSize="11" Foreground="#D7CCC8"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="120"/>
                        <TextBlock x:Name="VerBio"
                                   FontSize="10" Foreground="#D7CCC8" Opacity="0.75"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Утилиты (Utilities) -->
                <Button Style="{StaticResource TileStyle}" Background="#455A64"
                        Click="LaunchTools"
                        ToolTip="{DynamicResource TileToolsTip}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🧰" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TileTools}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{DynamicResource TileToolsSub}"
                                   FontSize="11" Foreground="#CFD8DC"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="120"/>
                        <TextBlock x:Name="VerTools"
                                   FontSize="10" Foreground="#CFD8DC" Opacity="0.75"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Инфо-блок: установленные программы (заполняется в коде) -->
                <Border Width="520" Height="152" Margin="10" CornerRadius="14"
                        Background="#FFEFF6EF" BorderBrush="#FFCBDDCB" BorderThickness="1"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="12,6,8,4">
                            <Button DockPanel.Dock="Right" Click="RefreshInstalled_Click"
                                    ToolTip="{DynamicResource InfoRefreshTip}" Cursor="Hand"
                                    Padding="6,1" Background="Transparent" BorderThickness="0" Focusable="False">
                                <TextBlock Text="🔄" FontSize="13"/>
                            </Button>
                            <TextBlock Text="{DynamicResource InfoHeader}" FontWeight="SemiBold"
                                       Foreground="#FF2C5F2D" FontSize="12" VerticalAlignment="Center"/>
                        </DockPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      Padding="12,0,12,8">
                            <StackPanel x:Name="InfoList"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

            </WrapPanel>
        </ScrollViewer>

        <!-- Подвал -->
        <Border Grid.Row="2" Background="#B8D4B8"
                BorderBrush="#9CBD9C" BorderThickness="0,1,0,0"
                Padding="20,7">
            <Grid>
                <TextBlock x:Name="tbVersion"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="#3A5A3A" HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{DynamicResource FooterInfo}"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="#3A5A3A" HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <Button Style="{StaticResource SettingsBtnStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="OpenSettings"
                        ToolTip="{DynamicResource SettingsTip}">
                    <TextBlock Text="⚙" FontSize="15" Foreground="#2C5F2D"/>
                </Button>
            </Grid>
        </Border>

    </Grid>
</Window>
