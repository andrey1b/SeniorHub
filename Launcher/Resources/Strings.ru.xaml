<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Шапка -->
    <sys:String x:Key="AppTitle">Офис пенсионера</sys:String>
    <sys:String x:Key="AppSubtitle">Девять программ — всё что нужно каждый день</sys:String>

    <!-- Плитки -->
    <sys:String x:Key="TileFood">Еда</sys:String>
    <sys:String x:Key="TileFoodSub">Меню и рацион</sys:String>
    <sys:String x:Key="TileFoodTip">Планировщик питания и меню</sys:String>

    <sys:String x:Key="TileGarden">Огород</sys:String>
    <sys:String x:Key="TileGardenSub">Планировщик грядок</sys:String>
    <sys:String x:Key="TileGardenTip">Планировщик огорода — грядки, севооборот, лунный календарь</sys:String>

    <sys:String x:Key="TileMoney">Деньги</sys:String>
    <sys:String x:Key="TileMoneySub">Чеки и расходы</sys:String>
    <sys:String x:Key="TileMoneyTip">Чеки → учёт домашних расходов</sys:String>

    <sys:String x:Key="TileMeds">Таблетки</sys:String>
    <sys:String x:Key="TileMedsSub">Приём лекарств</sys:String>
    <sys:String x:Key="TileMedsTip">Расписание приёма лекарств, напоминания</sys:String>

    <sys:String x:Key="TileAudio">Аудиокниги</sys:String>
    <sys:String x:Key="TileAudioSub">Текст в речь</sys:String>
    <sys:String x:Key="TileAudioTip">Конвертер текста в аудиокниги</sys:String>

    <sys:String x:Key="TilePdf">Документы</sys:String>
    <sys:String x:Key="TilePdfSub">Сборка PDF</sys:String>
    <sys:String x:Key="TilePdfTip">PDF Drive — объединение PDF, фото, текста и Word в один файл</sys:String>

    <sys:String x:Key="TileUtil">Коммуналка</sys:String>
    <sys:String x:Key="TileUtilSub">Счета и оплата</sys:String>
    <sys:String x:Key="TileUtilTip">Коммунальные счета — справочник предприятий, лицевые счета и оплата через банк</sys:String>

    <sys:String x:Key="TileBio">Биография</sys:String>
    <sys:String x:Key="TileBioSub">История жизни</sys:String>
    <sys:String x:Key="TileBioTip">Моя биография — рассказ о своей жизни → красивый PDF, генеалогическая вики или черновик для Википедии</sys:String>

    <sys:String x:Key="TileTools">Утилиты</sys:String>
    <sys:String x:Key="TileToolsSub">Раскладка, OCR</sys:String>
    <sys:String x:Key="TileToolsTip">Сборник утилит: исправление раскладки (Pause/Break) и распознавание текста со снимка экрана (OCR)</sys:String>

    <!-- Инфо-блок установленных программ -->
    <sys:String x:Key="InfoHeader">Установленные программы:</sys:String>

    <!-- Подвал -->
    <sys:String x:Key="VersionLabel">Версия</sys:String>
    <sys:String x:Key="FooterInfo">Все данные хранятся локально на этом компьютере</sys:String>

    <!-- Настройки -->
    <sys:String x:Key="SettingsTip">Настройки</sys:String>
    <sys:String x:Key="SettingsTitle">Настройки</sys:String>
    <sys:String x:Key="SettingsLangLabel">Язык интерфейса</sys:String>
    <sys:String x:Key="SettingsApply">Применить</sys:String>
    <sys:String x:Key="SettingsCancel">Отмена</sys:String>
    <sys:String x:Key="BtnCheckUpdates">Проверить обновления</sys:String>
    <sys:String x:Key="UpdatesGroupLabel">Обновления</sys:String>

    <!-- Резервное копирование -->
    <sys:String x:Key="BackupGroupLabel">Резервное копирование</sys:String>
    <sys:String x:Key="BackupHint">Сохраните копию своих данных на флешку или в «Документы». Программа также делает копии автоматически каждый день.</sys:String>
    <sys:String x:Key="BtnBackup">Сохранить копию…</sys:String>
    <sys:String x:Key="BtnRestore">Восстановить из копии…</sys:String>
    <sys:String x:Key="BackupFileFilter">Резервная копия (*.db)</sys:String>
    <sys:String x:Key="BackupDone">Резервная копия успешно сохранена.</sys:String>
    <sys:String x:Key="BackupFailed">Не удалось сохранить копию:</sys:String>
    <sys:String x:Key="RestoreConfirm">Текущие данные будут заменены данными из копии. Продолжить?</sys:String>
    <sys:String x:Key="RestoreDone">Данные успешно восстановлены из копии.</sys:String>
    <sys:String x:Key="RestoreFailed">Не удалось восстановить из копии:</sys:String>

    <!-- Профиль пользователя -->
    <sys:String x:Key="ProfileGroupLabel">Профиль пользователя</sys:String>
    <sys:String x:Key="ProfileNameLabel">Имя</sys:String>
    <sys:String x:Key="ProfileBirthLabel">Дата рождения (ДД.ММ.ГГГГ)</sys:String>

    <!-- Заглушки -->
    <sys:String x:Key="TileComingSoon">Скоро будет доступно</sys:String>
    <sys:String x:Key="MsgNoUpdates">Обновлений нет. У вас установлена последняя версия.</sys:String>

</ResourceDictionary>
