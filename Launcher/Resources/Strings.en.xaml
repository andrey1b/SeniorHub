<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Header -->
    <sys:String x:Key="AppTitle">Senior Hub</sys:String>
    <sys:String x:Key="AppSubtitle">Nine apps — everything you need every day</sys:String>

    <!-- Tiles -->
    <sys:String x:Key="TileFood">Food</sys:String>
    <sys:String x:Key="TileFoodSub">Menu &amp; meals</sys:String>
    <sys:String x:Key="TileFoodTip">Meal planner and menu</sys:String>

    <sys:String x:Key="TileGarden">Garden</sys:String>
    <sys:String x:Key="TileGardenSub">Bed planner</sys:String>
    <sys:String x:Key="TileGardenTip">Garden planner — beds, crop rotation, lunar calendar</sys:String>

    <sys:String x:Key="TileMoney">Money</sys:String>
    <sys:String x:Key="TileMoneySub">Bills &amp; expenses</sys:String>
    <sys:String x:Key="TileMoneyTip">Receipts → home expense tracking</sys:String>

    <sys:String x:Key="TileMeds">Meds</sys:String>
    <sys:String x:Key="TileMedsSub">Medication schedule</sys:String>
    <sys:String x:Key="TileMedsTip">Medication schedule and reminders</sys:String>

    <sys:String x:Key="TileAudio">Audiobooks</sys:String>
    <sys:String x:Key="TileAudioSub">Text to speech</sys:String>
    <sys:String x:Key="TileAudioTip">Text to audiobook converter</sys:String>

    <sys:String x:Key="TilePdf">Documents</sys:String>
    <sys:String x:Key="TilePdfSub">Build PDF</sys:String>
    <sys:String x:Key="TilePdfTip">PDF Drive — combine PDFs, photos, text and Word into one file</sys:String>

    <sys:String x:Key="TileUtil">Utilities</sys:String>
    <sys:String x:Key="TileUtilSub">Bills &amp; payment</sys:String>
    <sys:String x:Key="TileUtilTip">Communal bills — providers directory, accounts and payment via bank</sys:String>

    <sys:String x:Key="TileBio">Biography</sys:String>
    <sys:String x:Key="TileBioSub">Life story</sys:String>
    <sys:String x:Key="TileBioTip">My Biography — tell your life story → a nice PDF, a genealogy wiki, or a Wikipedia draft</sys:String>

    <sys:String x:Key="TileTools">Tools</sys:String>
    <sys:String x:Key="TileToolsSub">Layout, OCR</sys:String>
    <sys:String x:Key="TileToolsTip">Toolbox: keyboard layout fix (Pause/Break) and screen text recognition (OCR)</sys:String>

    <!-- Installed-programs info block -->
    <sys:String x:Key="InfoHeader">Installed programs:</sys:String>
    <sys:String x:Key="InfoRefreshTip">Refresh installed-programs info</sys:String>
    <sys:String x:Key="InfoUpdateAll">⬇ Update all</sys:String>
    <sys:String x:Key="InfoUpdateAllTip">Check for updates and update all programs at once</sys:String>
    <sys:String x:Key="InfoChecking">Checking…</sys:String>
    <sys:String x:Key="InfoAllUpToDate">All programs are up to date.</sys:String>

    <!-- Footer -->
    <sys:String x:Key="VersionLabel">Version</sys:String>
    <sys:String x:Key="FooterInfo">All data is stored locally on this computer</sys:String>

    <!-- Settings -->
    <sys:String x:Key="SettingsTip">Settings</sys:String>
    <sys:String x:Key="SettingsTitle">Settings</sys:String>
    <sys:String x:Key="SettingsLangLabel">Interface language</sys:String>
    <sys:String x:Key="SettingsApply">Apply</sys:String>
    <sys:String x:Key="SettingsCancel">Cancel</sys:String>
    <sys:String x:Key="BtnCheckUpdates">Check for updates</sys:String>
    <sys:String x:Key="UpdatesGroupLabel">Updates</sys:String>

    <!-- Backup -->
    <sys:String x:Key="BackupGroupLabel">Backup</sys:String>
    <sys:String x:Key="BackupHint">Save a copy of all your apps' data to a USB drive or Documents. The program also makes copies automatically every day.</sys:String>
    <sys:String x:Key="BtnBackup">Save a copy…</sys:String>
    <sys:String x:Key="BtnRestore">Restore from a copy…</sys:String>
    <sys:String x:Key="BackupFileFilter">Backup file</sys:String>
    <sys:String x:Key="BackupDone">Backup saved successfully.</sys:String>
    <sys:String x:Key="BackupFailed">Failed to save the copy:</sys:String>
    <sys:String x:Key="RestoreConfirm">Current data will be replaced with the data from the copy. Continue?</sys:String>
    <sys:String x:Key="RestoreDone">Data restored successfully from the copy.</sys:String>
    <sys:String x:Key="RestoreFailed">Failed to restore from the copy:</sys:String>

    <!-- User profile -->
    <sys:String x:Key="ProfileGroupLabel">User Profile</sys:String>
    <sys:String x:Key="ProfileNameLabel">Name</sys:String>
    <sys:String x:Key="ProfileBirthLabel">Date of birth (DD.MM.YYYY)</sys:String>

    <!-- Stubs -->
    <sys:String x:Key="TileComingSoon">Coming soon</sys:String>
    <sys:String x:Key="MsgNoUpdates">No updates available. You have the latest version.</sys:String>

</ResourceDictionary>
